{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "cd hv1 && npm install --include=dev && npm run build",
  "outputDirectory": "hv1/dist",
  "installCommand": "echo skip-root-install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
